<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">#CCFFFFFF</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:colorBackground">@android:color/transparent</item>

        <item name="android:textColor">#FFFFFF</item>

        <item name="materialButtonStyle">@style/GlassButton</item>
        <item name="editTextStyle">@style/GlassInput</item>
        <item name="android:windowBackground">@drawable/blue</item>
        <item name="bottomNavigationStyle">@style/GlassBottomNav</item>

    </style>

    <style name="GlassButton" parent="Widget.MaterialComponents.Button">

        <!-- Kill Material background -->
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/bg_glass_button</item>

        <!-- Text -->
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>

        <!-- Remove extra paddings -->
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>

        <item name="android:padding">12dp</item>
    </style>

    <style name="GlassButton.Danger" parent="GlassButton">
        <item name="android:textColor">#FF4444</item>
        <item name="android:backgroundTint">#1FFF0000</item>
        <item name="strokeColor">#FF4444</item>
    </style>

    <style name="GlassInput" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="GlassCard">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="GlassRoundButton">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:background">@drawable/bg_glass_round</item>

        <item name="android:tint">#FFFFFF</item>
        <item name="android:padding">0dp</item>

        <item name="android:elevation">6dp</item>
    </style>

    <style name="GlassBottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@drawable/bg_glass_nav</item>
        <item name="itemIconTint">@android:color/white</item>
        <item name="itemTextColor">@android:color/white</item>
    </style>

</resources>